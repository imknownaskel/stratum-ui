# Local API
API_PORT=3001
APP_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Public URL used in confirmation and password-reset emails.
# Replace this with your deployed HTTPS domain before cross-device testing.
APP_PUBLIC_URL=http://127.0.0.1:5173

# Supabase project URL from Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Safe for browser code. Keep Row Level Security enabled.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Server-only. Never use a VITE_ prefix for this value.
SUPABASE_SECRET_KEY=sb_secret_your-key
# Server-only NVIDIA NIM configuration. Never use a VITE_ prefix.
NVIDIA_NIM_API_KEY=nvapi-your-key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_FAST_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_NIM_REASONING_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_NIM_CHALLENGER_MODEL=google/gemma-4-31b-it
NVIDIA_NIM_TIMEOUT_MS=180000
AI_PROMPT_VERSION=policy-v3
AI_ESCALATION_THRESHOLD=0.78
AI_CHUNK_CHARACTERS=80000
AI_CHUNK_CONCURRENCY=2
POLICY_WORKER_POLL_MS=3000

# Summary language. nvidia generates directly in the selected language.
# google analyzes in English, then translates user-facing fields server-side.
TRANSLATION_PROVIDER=nvidia
GOOGLE_TRANSLATE_API_KEY=your-server-only-google-cloud-translation-key
TRANSLATION_TIMEOUT_MS=30000
